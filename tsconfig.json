{
	"compilerOptions": {
		// Core & Bundler
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"allowSyntheticDefaultImports": true,
		"esModuleInterop": true,
		"noEmit": true, // SolidStart handles the file generation
		"skipLibCheck": true,
		"strict": true,
		"verbatimModuleSyntax": true,
		// SolidJS
		"allowJs": true,
		"jsx": "preserve",
		"jsxImportSource": "solid-js",
		"paths": {
			"~/*": ["./src/*"]
		}
	}
}
